{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite-dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite v",
          "endsPattern": "Local:|Network:"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
